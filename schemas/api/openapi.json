            "nullable": true
          },
          "stageCompleted": {
            "type": "boolean",
            "example": false,
            "description": "Chặng đã hoàn thành chưa"
          },
          "nextChestIndex": {
            "type": "object",
            "example": 1,
            "description": "Chỉ số rương tiếp theo (null nếu đã hết)",
            "nullable": true
          },
          "nextStage": {
            "type": "object",
            "description": "Chặng tiếp theo sau khi hoàn thành rương ký tự (null nếu hết chặng)",
