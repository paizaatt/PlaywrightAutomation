{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@config/*": ["config/*"],
      "@components/*": ["src/components/*"],
      "@api-core/*": ["src/api-core/*"],
      "@api-components/*": ["src/api-components/*"],
      "@api-services/*": ["src/api-services/*"],
      "@fixtures/*": ["src/fixtures/*"],
      "@pages/*": ["src/pages/*"],
      "@utils/*": ["src/utils/*"],
      "@types/*": ["src/types/*"]
    }
  },
  "include": ["config/**/*.ts", "src/**/*.ts", "tests/**/*.ts", "schemas/**/*.json"]
}
