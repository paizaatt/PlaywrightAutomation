            "example": {
              "stageId": "507f1f77bcf86cd799439011",
              "stageOrder": 2,
              "name": "Chặng 2",
              "status": "in_progress",
              "unlocked": true
            }
          },
          "message": {
            "type": "string",
            "example": "Chúc mừng! Bạn nhận được 50,000 VND",
            "description": "Thông báo"
          }
        },
        "required": [
          "ok",
          "canOpen",
          "chestIndex",
          "isCharChest",
          "rewardAmount",
          "isTrapFailed",
          "collectedChar",
          "stageCompleted",
          "nextChestIndex",
          "nextStage",
          "message"
        ]
      },
      "SpinResultDto": {
        "type": "object",
