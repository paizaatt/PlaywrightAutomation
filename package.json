{
  "name": "playwright-auto-truytimkhobau",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "playwright test --config=config/playwright.config.ts",
    "test:headed": "playwright test --config=config/playwright.config.ts --headed",
    "test:ui": "playwright test --config=config/playwright.config.ts --ui",
    "report": "playwright show-report",
    "run:auto": "node run-auto.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0"
  },
  "dependencies": {
    "ghost-cursor": "^1.4.2",
    "playwright": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
