            "items": {
              "type": "array",
              "items": {
                "type": "a"
              }
            },
            "type": "array"
          }
        },
        "required": [
          "eligible",
          "alreadySpun",
          "collectedChars",
          "missingChars",
          "prizes"
        ]
      },
      "SpinResponseDto": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true,
            "description": "Quay thành công hay không"
          },
