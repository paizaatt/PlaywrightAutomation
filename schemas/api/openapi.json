            "items": {
              "$ref": "#/components/schemas/ChestDto"
            }
          }
        },
        "required": [
          "stageId",
          "stageOrder",
          "name",
          "status",
          "stageConditions",
          "allStageConditionsMet",
          "chests"
        ]
      },
      "OpenChestRequestDto": {
        "type": "object",
        "properties": {
          "stageId": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011",
            "description": "ID của chặng (24 ký tự hex - MongoDB ObjectId)",
            "pattern": "^[a-f\\d]{24}$",
            "minLength": 24,
            "maxLength": 24
          },
          "chestIndex": {
            "type": "number",
            "example": 0,
            "description": "Chỉ số rương (0-5, trong đó 5 là rương ký tự)",
            "minimum": 0,
            "maximum": 5,
            "format": "int32"
          }
        },
        "required": [
          "stageId",
          "chestIndex"
        ]
      },
      "OpenChestSuccessDto": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true,
            "description": "Thành công hay không"
          },
          "canOpen": {
            "type": "boolean",
            "example": true,
            "description": "Có thể mở rương không"
          },
          "chestIndex": {
            "type": "number",
            "example": 0,
            "description": "Chỉ số rương vừa mở"
          },
          "isCharChest": {
            "type": "boolean",
            "example": false,
            "description": "Có phải rương ký tự không"
          },
          "rewardAmount": {
            "type": "number",
            "example": 50000,
            "description": "Số tiền thưởng"
          },
          "isTrapFailed": {
            "type": "boolean",
            "example": false,
            "description": "Có trúng bẫy không"
          },
          "collectedChar": {
            "type": "object",
            "example": null,
